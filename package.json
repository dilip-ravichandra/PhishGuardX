{
  "name": "phishguardx",
  "version": "0.1.0",
  "private": true,
  "description": "PhishGuardX - AI-Powered Enterprise Email Phishing Detection Platform",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
