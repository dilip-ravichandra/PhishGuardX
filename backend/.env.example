# Server
PORT=4000
NODE_ENV=development

# Database (required as of Milestone 1)
MONGODB_URI=mongodb://localhost:27017/phishguardx

# Auth (required as of Milestone 1)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AI Service (used from Milestone 4 onward; not yet consumed)
AI_SERVICE_URL=http://localhost:8000

# Threat Intelligence providers (used from Milestone 5 onward; not yet consumed)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
PHISHTANK_API_KEY=
URLSCAN_API_KEY=
WHOIS_API_KEY=

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# Uploads (used from Milestone 3 onward; not yet consumed)
MAX_UPLOAD_SIZE_MB=10
